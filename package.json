{
  "name": "review",
  "productName": "review",
  "version": "1.0.1",
  "description": "My Electron application description",
  "main": ".webpack/main",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "clean:release": "powershell -NoProfile -Command \"Remove-Item -Recurse -Force .webpack,dist,out -ErrorAction SilentlyContinue\"",
    "dist": "npm run clean:release && npm run package && electron-builder",
    "pack": "electron-builder --dir",
    "lint": "echo \"No linting configured\""
  },
  "keywords": [],
  "author": "admin",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-webpack": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/recharts": "^1.8.29",
    "@vercel/webpack-asset-relocator-loader": "^1.7.3",
    "autoprefixer": "^10.4.27",
    "css-loader": "^6.11.0",
    "electron": "40.8.0",
    "electron-builder": "^24.6.0",
    "node-loader": "^2.1.0",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "style-loader": "^3.3.4",
    "tailwindcss": "^4.2.1",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.laugfs.tyretech",
    "productName": "TyreTech",
    "asarUnpack": [
      "**/*.node"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      ".webpack/**/*",
      "**/*",
      "!**/*.ts",
      "!**/*.tsx",
      "!**/*.map",
      "!src/**/*.ts",
      "!src/**/*.tsx"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "TyreTech",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.3.1",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "embla-carousel-react": "^8.6.0",
    "keytar": "^7.9.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2"
  }
}
